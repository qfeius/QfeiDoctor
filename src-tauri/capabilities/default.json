{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "ms-settings:*" }
      ]
    }
  ]
}
