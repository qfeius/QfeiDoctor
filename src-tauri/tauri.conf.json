{
  "$schema": "https://raw.githubusercontent.com/nicepkg/gpt-runner/main/schemas/tauri-conf-v2.json",
  "productName": "QfeiDoctor",
  "version": "0.1.0",
  "identifier": "com.qfeius.qfeidoctor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "智书诊断助手 - QfeiDoctor",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
