{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qfeius.github.io/QfeiDoctor/schemas/diagnostic-result-v0.json",
  "title": "QfeiDoctor Diagnostic Result v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "target",
    "summary",
    "dns",
    "tcp",
    "tls",
    "http",
    "system",
    "recommended_actions"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "kind", "normalized_url", "domain", "port"],
      "properties": {
        "input": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["url", "domain"]
        },
        "normalized_url": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "severity",
        "total_duration_ms",
        "failure_stage",
        "resolved_ip"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "total_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "failure_stage": {
          "type": ["string", "null"],
          "enum": ["dns", "tcp", "tls", "http", "system", null]
        },
        "resolved_ip": {
          "type": ["string", "null"]
        }
      }
    },
    "dns": {
      "allOf": [
        { "$ref": "#/$defs/module" },
        {
          "type": "object",
          "required": ["details"],
          "properties": {
            "details": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "records",
                "resolved",
                "resolved_ip",
                "suspected_hijack",
                "private_ip"
              ],
              "properties": {
                "records": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "value", "ttl"],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["A", "AAAA", "CNAME"]
                      },
                      "value": {
                        "type": "string"
                      },
                      "ttl": {
                        "type": "integer",
                        "minimum": 0
                      }
                    }
                  }
                },
                "resolved": {
                  "type": "boolean"
                },
                "resolved_ip": {
                  "type": ["string", "null"]
                },
                "suspected_hijack": {
                  "type": "boolean"
                },
                "private_ip": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      ]
    },
    "tcp": {
      "allOf": [
        { "$ref": "#/$defs/module" },
        {
          "type": "object",
          "required": ["details"],
          "properties": {
            "details": {
              "type": "object",
              "additionalProperties": false,
              "required": ["connected", "ip", "port"],
              "properties": {
                "connected": {
                  "type": "boolean"
                },
                "ip": {
                  "type": ["string", "null"]
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                }
              }
            }
          }
        }
      ]
    },
    "tls": {
      "allOf": [
        { "$ref": "#/$defs/module" },
        {
          "type": "object",
          "required": ["details"],
          "properties": {
            "details": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "handshake",
                "version",
                "cert"
              ],
              "properties": {
                "handshake": {
                  "type": "boolean"
                },
                "version": {
                  "type": ["string", "null"]
                },
                "cert": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "valid",
                    "expired",
                    "expiring_soon",
                    "days_remaining",
                    "domain_mismatch",
                    "chain_incomplete",
                    "self_signed",
                    "issuer",
                    "subject",
                    "not_before",
                    "not_after"
                  ],
                  "properties": {
                    "valid": { "type": "boolean" },
                    "expired": { "type": "boolean" },
                    "expiring_soon": { "type": "boolean" },
                    "days_remaining": { "type": ["integer", "null"] },
                    "domain_mismatch": { "type": "boolean" },
                    "chain_incomplete": { "type": "boolean" },
                    "self_signed": { "type": "boolean" },
                    "issuer": { "type": ["string", "null"] },
                    "subject": { "type": ["string", "null"] },
                    "not_before": { "type": ["string", "null"] },
                    "not_after": { "type": ["string", "null"] }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "http": {
      "allOf": [
        { "$ref": "#/$defs/module" },
        {
          "type": "object",
          "required": ["details"],
          "properties": {
            "details": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status_code",
                "redirect_chain",
                "headers",
                "empty_body",
                "downgraded"
              ],
              "properties": {
                "status_code": {
                  "type": ["integer", "null"],
                  "minimum": 100,
                  "maximum": 599
                },
                "redirect_chain": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "headers": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "empty_body": { "type": "boolean" },
                "downgraded": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },
    "system": {
      "allOf": [
        { "$ref": "#/$defs/module" },
        {
          "type": "object",
          "required": ["details"],
          "properties": {
            "details": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "proxy",
                "clock_skewed",
                "clock_offset_sec",
                "hosts_override"
              ],
              "properties": {
                "proxy": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["enabled", "type", "address", "pac_url", "env_var"],
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "type": {
                      "type": ["string", "null"],
                      "enum": ["system", "pac", "env", null]
                    },
                    "address": { "type": ["string", "null"] },
                    "pac_url": { "type": ["string", "null"] },
                    "env_var": { "type": ["string", "null"] }
                  }
                },
                "clock_skewed": { "type": "boolean" },
                "clock_offset_sec": { "type": ["integer", "null"] },
                "hosts_override": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },
    "recommended_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_actions", "quick_actions"],
      "properties": {
        "manual_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quick_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "kind", "target"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "kind": { "type": "string", "enum": ["open_uri"] },
              "target": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "fail", "skip"]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warn", "fail"]
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "severity", "duration_ms", "error"],
      "properties": {
        "status": { "$ref": "#/$defs/status" },
        "severity": { "$ref": "#/$defs/severity" },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
